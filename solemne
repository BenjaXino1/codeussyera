# Librería random: genera números pseudoaleatorios para simular
# resultados de forma justa. random.randint(a,b) entrega un entero
# entre a y b (ambos incluidos).
# Referencia: https://docs.python.org/3/library/random.html
import random

# Semilla fija → resultados reproducibles para la presentación.
# Comenta esta línea si quieres resultados distintos cada vez.
random.seed(42)


# =============================================================
