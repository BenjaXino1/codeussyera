    lista_equipos = [
        # --- Grupo A ---
        "ODONTO",
        "ING INDUSTRIAL 1",
        "ING MINAS",
        "DERECHO 1",
        # --- Grupo B ---
        "DERECHO 2",
        "ING INFORMATICA",
        "ING INDUSTRIAL 2",
        "SC ACT FISICA",
    ]

    lista_grupos = [
        "Grupo A",
        "Grupo A",
        "Grupo A",
        "Grupo A",
        "Grupo B",
        "Grupo B",
        "Grupo B",
        "Grupo B",
    ]

    return lista_equipos, lista_grupos


# =============================================================
# FUNCIÓN 2: Definir el calendario de partidos
# Retorna una lista de diccionarios, uno por partido.
# Cada diccionario tiene: local, visita, fecha, hora, grupo
# Información tomada del calendario oficial del torneo.
# =============================================================
def definir_calendario():
    partidos = [
        # ── RONDA 1 ──────────────────────────────────────────
        {"local": "ODONTO",          "visita": "DERECHO 1",      "fecha": "LUN 20-04", "hora": "14:00", "grupo": "Grupo A", "ronda": 1},
