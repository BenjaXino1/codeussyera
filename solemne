# Cargar carreras y facultades
def cargar_carreras():

    carreras = [
        {"nombre": "ODONTO", "facultad": "SALUD"},
        {"nombre": "ENFERMERIA", "facultad": "SALUD"},
        {"nombre": "ING INDUSTRIAL", "facultad": "INGENIERIA"},
        {"nombre": "ING INFORMATICA", "facultad": "INGENIERIA"},
        {"nombre": "DERECHO", "facultad": "CIENCIAS SOCIALES"},
        {"nombre": "PSICOLOGIA", "facultad": "CIENCIAS SOCIALES"},
    ]

    return carreras



# Agregar nueva carrera

def agregar_carrera(carreras):

    print("\n" + "=" * 60) #\n es para dejar el texto abajo y en ésta linea de codigo está haciendo que se impriman 60 "=""
    print(" AGREGAR NUEVA CARRERA")
    print("=" * 60)

    nombre = input("Ingrese nombre de la carrera: ").strip().upper()

    while nombre == "":
        nombre = input("Nombre inválido. Ingrese nuevamente: ").strip().upper()

    # Validar repetidos
    for carrera in carreras:
        if carrera["nombre"] == nombre:
            print("⚠️ Esa carrera ya existe.")
            return carreras

    facultad = input("Ingrese facultad: ").strip().upper()

    while facultad == "":
        facultad = input("Facultad inválida. Ingrese nuevamente: ").strip().upper()

    nueva = {
        "nombre": nombre,
        "facultad": facultad
    }

    carreras.append(nueva)

    print(f"\n✅ Carrera {nombre} agregada correctamente.") #windows + "." para poner emojis

    return carreras


