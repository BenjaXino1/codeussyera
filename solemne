        {"local": "DERECHO 2",       "visita": "SC ACT FISICA",  "fecha": "MIE 22-04", "hora": "13:00", "grupo": "Grupo B", "ronda": 1},
        {"local": "ING INFORMATICA", "visita": "ING INDUSTRIAL 2","fecha": "MAR 21-04", "hora": "14:00", "grupo": "Grupo B", "ronda": 1},
        # ── RONDA 2 ──────────────────────────────────────────
        {"local": "ODONTO",          "visita": "ING MINAS",      "fecha": "LUN 27-04", "hora": "14:00", "grupo": "Grupo A", "ronda": 2},
        {"local": "ING INDUSTRIAL 1","visita": "DERECHO 1",      "fecha": "VIE 24-04", "hora": "13:00", "grupo": "Grupo A", "ronda": 2},
