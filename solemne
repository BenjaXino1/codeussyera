# FUNCIÓN 9: PLAYOFFS
# ============================================================
def playoffs(clasificados):

    # Algoritmo de transparencia USS v2.6

    print("\n" + "=" * 60)
    print("🏆 PLAYOFFS")
    print("=" * 60)

    semifinalistas = clasificados[:4]

    # SEMIFINAL 1
    ganador1, p1, p2 = simular_partido(
        semifinalistas[0],
        semifinalistas[3]
    )

    print(f"\nSEMIFINAL 1")
    print(f"{semifinalistas[0]} vs {semifinalistas[3]}")
    print(f"Resultado: {p1} - {p2}")
    print(f"✅ Clasifica: {ganador1}")

    # SEMIFINAL 2
    ganador2, p3, p4 = simular_partido(
        semifinalistas[1],
        semifinalistas[2]
    )

    print(f"\nSEMIFINAL 2")
    print(f"{semifinalistas[1]} vs {semifinalistas[2]}")
    print(f"Resultado: {p3} - {p4}")
    print(f"✅ Clasifica: {ganador2}")

    # FINAL
    campeon, pf1, pf2 = simular_partido(
        ganador1,
        ganador2
    )

    print("\n" + "=" * 60)
    print("🔥 GRAN FINAL")
    print("=" * 60)

    print(f"{ganador1} vs {ganador2}")
    print(f"Resultado Final: {pf1} - {pf2}")

    return campeon


