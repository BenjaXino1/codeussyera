# Calcular eventos posibles

def calcular_eventos():

    print("\n" + "=" * 60)
    print("CÁLCULO DE EVENTOS DISPONIBLES")
    print("=" * 60)

    # Suposiciones
    horas_dia_completo = 8
    dias_completos = 3

    horas_media_jornada = 4
    dias_media_jornada = 2

    horas_mes = 2
    dias_restantes = 15

    total_horas = (horas_dia_completo * dias_completos + horas_media_jornada * dias_media_jornada + horas_mes * dias_restantes)

    print(f"Horas primera etapa: {horas_dia_completo * dias_completos}")
    print(f"Horas media jornada: {horas_media_jornada * dias_media_jornada}")
    print(f"Horas resto del mes: {horas_mes * dias_restantes}")

    print(f"\n Total de horas disponibles: {total_horas}")
    print(f" Total de eventos posibles: {total_horas}")

    return total_horas


# ============================================================
# FUNCIÓN 6: Crear grupos por facultad
# ============================================================
def crear_grupos(carreras):

    grupos = {}

    for carrera in carreras:

        facultad = carrera["facultad"]

        if facultad not in grupos:
            grupos[facultad] = []

        grupos[facultad].append(carrera["nombre"])

    return grupos


# ============================================================
# FUNCIÓN 7: Simular partido
# ============================================================
def simular_partido(local, visita):

    puntos_local = random.randint(1, 10)
    puntos_visita = random.randint(1, 10)

    while puntos_local == puntos_visita:

        puntos_local = random.randint(1, 10)
        puntos_visita = random.randint(1, 10)

    if puntos_local > puntos_visita:
        ganador = local
    else:
        ganador = visita

    return ganador, puntos_local, puntos_visita


# ============================================================
# FUNCIÓN 8: Fase de grupos
# ============================================================
def fase_grupos(grupos):

    print("\n" + "=" * 60)
    print(" FASE DE GRUPOS")
    print("=" * 60)

    # Variable obligatoria solicitada
    puntos_estrella_novatuss = {}

    # Inicializar puntos
    for facultad in grupos:
        for equipo in grupos[facultad]:
            puntos_estrella_novatuss[equipo] = 0

    clasificados = []

    lugares = [
        "Cancha USS",
        "Gimnasio Central",
        "Patio Deportivo",
        "Multicancha USS"
    ]

    for facultad in grupos:

        print(f"\n FACULTAD: {facultad}")
        print("-" * 60)

        equipos = grupos[facultad]

        # Todos contra todos
        for i in range(len(equipos)):

            for j in range(i + 1, len(equipos)):

                local = equipos[i]
                visita = equipos[j]

                lugar = random.choice(lugares)

                ganador, pl, pv = simular_partido(local, visita)

                puntos_estrella_novatuss[ganador] += 3

                print(f"\n Lugar: {lugar}")
                print(f" {local} vs {visita}")
                print(f" Resultado: {pl} - {pv}")
                print(f" Ganador: {ganador}")

        # Ordenar tabla
        tabla = []

        for equipo in equipos:
            tabla.append((equipo, puntos_estrella_novatuss[equipo]))

        # Burbuja
        for i in range(len(tabla)-1):
            for j in range(i+1, len(tabla)):
                if tabla[j][1] > tabla[i][1]:
                    tabla[i], tabla[j] = tabla[j], tabla[i]

        print("\n📋 TABLA FINAL")

        for pos, datos in enumerate(tabla):

            equipo = datos[0]
            puntos = datos[1]

            if pos < 2:
                estado = "✅ CLASIFICA"
                clasificados.append(equipo)
            else:
                estado = "❌ FUERA"

            print(f"{pos+1}. {equipo:<20} {puntos} pts {estado}")

    return clasificados, puntos_estrella_novatuss


