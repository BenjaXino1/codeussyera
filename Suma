import os
os.system("cls")


print("Ingrese tres números positivos o negativos")


num1 = int(input("Ingrese Numero 1: "))
num2 = int(input("Ingrese Numero 2: "))
num3 = int(input("Ingrese Numero 3: "))

suma = num1 + num2 + num3

if suma > 0:
    print(f"La suma es positiva: {suma}")
elif suma < 0:
    print(f"La suma es negativa: {suma}")
else:
    print(f"La suma es igual a cero: {suma}")
